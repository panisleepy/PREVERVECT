{
  "manifest_version": 3,
  "name": "PREVERVECT Detector",
  "version": "0.1.0",
  "description": "Capture video frames and send to PREVERVECT backend.",
  "permissions": [],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "https://*/*",
    "http://*/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*/*",
        "http://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "PREVERVECT",
    "default_popup": "popup.html"
  }
}
